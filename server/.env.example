# Google OAuth (Client in der Google Cloud Console; Redirect-URI:
# http://localhost:3009/api/auth/google/callback fuer Dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Kommagetrennte Whitelist fuer den Login (Unterzeichner-E-Mails aus den
# Gesellschafter-Stammdaten haben automatisch Zugang)
ALLOWED_EMAILS=mf@taikonauten.com

# LLM: direkter Gemini-Key (gleiches Muster wie TaikoEat/TaikoTasks).
# Default-Endpoint ist Googles OpenAI-kompatible API; per LLM_BASE_URL
# spaeter auf ein Gateway umstellbar.
LLM_API_KEY=
# Praeferenz-Reihenfolge (Discovery via GET /models, Fallback bei 429/5xx)
LLM_MODELS=gemini-3.1-pro,gemini-3.5-flash

# Dev-Login ohne OAuth (nur lokal!): DEV_LOGIN=1

# Produktion
# SESSION_SECRET=
# APP_URL=
